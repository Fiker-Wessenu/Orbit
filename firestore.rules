rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isParticipant(chatId) {
      return isSignedIn() &&
        request.auth.uid in
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }


    // ═══════════════════════════════════════════════════════
    // USERS  →  users/{uid}
    // ═══════════════════════════════════════════════════════
    match /users/{uid} {

      allow read: if isSignedIn();

      // Only the user themselves can create their own profile,
      // and only if their auth email is on the required domain.
      allow create: if isOwner(uid) &&
        request.auth.token.email.matches('.*@ssgi[.]gov[.]et$');

      allow update: if isOwner(uid) &&
        !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['uid', 'email']);

      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════
    // CHATS  →  chats/{chatId}
    // (a "group" is simply a chat doc with type == 'group')
    // ═══════════════════════════════════════════════════════
    match /chats/{chatId} {

      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participants;

      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.createdBy == request.auth.uid;

      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants &&
        (
          resource.data.type != 'group' ||
          !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['groupName', 'groupPhotoUrl', 'admins', 'participants']) ||
          request.auth.uid in resource.data.admins
        );

      allow delete: if false;


      // ═══════════════════════════════════════════════════════
      // MESSAGES  →  chats/{chatId}/messages/{messageId}
      // ═══════════════════════════════════════════════════════
      match /messages/{messageId} {

        allow read: if isParticipant(chatId);

        allow create: if isParticipant(chatId) &&
          request.resource.data.senderId == request.auth.uid;

        allow update: if isParticipant(chatId) && (
          (
            resource.data.senderId == request.auth.uid &&
            !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['senderId', 'createdAt'])
          )
          ||
          (
            request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['readBy', 'status'])
          )
        );

        allow delete: if isParticipant(chatId) &&
          resource.data.senderId == request.auth.uid;
      }
    }


    // ═══════════════════════════════════════════════════════
    // PRESENCE  →  presence/{uid}
    // (placeholder — basic version, refine when we design this)
    // ═══════════════════════════════════════════════════════
    match /presence/{uid} {

      allow read: if isSignedIn();

      allow write: if isOwner(uid);
    }
  }
}